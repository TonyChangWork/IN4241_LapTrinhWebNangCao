@model SneakerAdmin.Models.User

@{
    ViewData["Title"] = "Xóa người dùng";
}

<h2>Xác nhận xóa</h2>

<div class="alert alert-danger">
    Bạn có chắc muốn xóa người dùng <strong>@Model.Name</strong> không?
</div>

<div class="card" style="max-width:400px">
    <div class="card-body">
        <p><strong>Họ tên:</strong> @Model.Name</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Vai trò:</strong> @Model.Role</p>
        <p><strong>Ngày đăng ký:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy</a>
</form>