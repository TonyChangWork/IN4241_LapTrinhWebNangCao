@model SneakerAdmin.Models.Product

@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<h2>Sửa sản phẩm</h2>

<form asp-action="Edit" method="post" style="max-width:500px">
    <input asp-for="Id" type="hidden" />
    <div class="mb-3">
        <label class="form-label">Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Thương hiệu</label>
        <select asp-for="Brand" class="form-control">
            <option>Nike</option>
            <option>Adidas</option>
            <option>Puma</option>
            <option>Jordan</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Giá ($)</label>
        <input asp-for="Price" class="form-control" type="number" />
    </div>
    <div class="mb-3">
        <label class="form-label">Link ảnh</label>
        <input asp-for="Image" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Tồn kho</label>
        <input asp-for="Stock" class="form-control" type="number" />
    </div>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy</a>
</form>