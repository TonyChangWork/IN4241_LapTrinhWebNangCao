@model SneakerAdmin.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<h2>Thêm sản phẩm mới</h2>

<form asp-action="Create" method="post" style="max-width:500px">
    <div class="mb-3">
        <label class="form-label">Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" placeholder="Nike Air Force 1" />
    </div>
    <div class="mb-3">
        <label class="form-label">Thương hiệu</label>
        <select asp-for="Brand" class="form-control">
            <option>Nike</option>
            <option>Adidas</option>
            <option>Puma</option>
            <option>Jordan</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Giá ($)</label>
        <input asp-for="Price" class="form-control" type="number" placeholder="120" />
    </div>
    <div class="mb-3">
        <label class="form-label">Link ảnh</label>
        <input asp-for="Image" class="form-control" placeholder="https://..." />
    </div>
    <div class="mb-3">
        <label class="form-label">Tồn kho</label>
        <input asp-for="Stock" class="form-control" type="number" placeholder="50" />
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy</a>
</form>